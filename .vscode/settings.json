{
	"stylua.targetReleaseVersion": "latest",
	 "workbench.editor.customLabels.patterns": {
        "**/init.lua": "${dirname} (${filename}.${extname})",
        "**/init.luau": "${dirname} (${filename}.${extname})",
		"**/Client.luau": "${dirname}${filename}.${extname}",
		"**/Server.luau": "${dirname}${filename}.${extname}",
		"**/Utils.luau": "${dirname}${filename}.${extname}",
	},
	"luau-lsp.completion.autocompleteEnd": true,
	"luau-lsp.completion.enableFragmentAutocomplete": true,
	"luau-lsp.completion.imports.separateGroupsWithLine": true,
	"luau-lsp.completion.imports.stringRequires.enabled": false,
	"luau-lsp.completion.showPropertiesOnMethodCall": true,
	"luau-lsp.diagnostics.strictDatamodelTypes": true,
	"luau-lsp.diagnostics.workspace": true,
	"luau-lsp.fflags.enableByDefault": true,
	"luau-lsp.fflags.enableNewSolver": true,
	"luau-lsp.format.convertQuotes": false,
	"luau-lsp.hover.multilineFunctionDefinitions": true,
	"luau-lsp.hover.showTableKinds": true,
	"luau-lsp.inlayHints.functionReturnTypes": false,
	"luau-lsp.inlayHints.hideHintsForErrorTypes": false,
	"luau-lsp.inlayHints.parameterTypes": false,
	"luau-lsp.inlayHints.variableTypes": false,
	"luau-lsp.plugin.enabled": true,
	"luau-lsp.fflags.sync": false,
	"luau-lsp.inlayHints.hideHintsForMatchingParameterNames": false,
	"luau-lsp.inlayHints.makeInsertable": false,
}